# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ALLOWED_USER_IDS=123456789  # comma-separated Telegram user IDs

# ── Dicord ──────────────────────────────────────────
DISCORD_BOT_TOKEN=REPLACE_ME
DISCORD_ALLOWED_USER_IDS=1316152250510348500

# ── Anthropic (Claude) — Level 1 ─────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OpenAI — Level 3 (Whisper transcription) ─────────
OPENAI_API_KEY=sk-proj-your-key-here

# ── ElevenLabs — Level 3 (Text-to-speech) ────────────
ELEVENLABS_API_KEY=sk_your-key-here

# ── OpenRouter — Optional (multi-model routing) ──────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Gmail ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token

# ── Groq — Optional (fast inference fallback) ────────
GROQ_API_KEY=gsk_your-key-here

# ── Model Config ─────────────────────────────────────
PROVIDER=anthropic  # 'anthropic' or 'openrouter'
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_AGENT_ITERATIONS=10

# ── Notion ─────────────────────────────────────────────
NOTION_API_KEY=your-notion-internal-integration-secret
